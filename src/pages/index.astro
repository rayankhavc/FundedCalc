---
/**
 * FundedCalc — index.astro
 * Entry point with full SEO meta stack.
 *
 * Before deploying:
 *  1. Replace https://fundedcalc.fr with your actual domain
 *  2. Add /public/og-fundedcalc.png (1200×630) — you can use a share card
 *     generated by the app itself as the OG image
 *  3. Add /public/favicon.svg and /public/favicon.ico
 */
import App from '../components/App.jsx';

const SITE_URL  = 'https://fundedcalc.fr';
const OG_IMAGE  = `${SITE_URL}/og-fundedcalc.png`;
const TITLE     = 'FundedCalc — Prop Firm Challenge Probability Calculator';
const DESC      = 'Calculate your prop firm challenge pass probability with 5,000 Monte Carlo simulations. Supports FTMO, FundedNext, Funding Pips, Blue Guardian, FunderPro, Alpha Capital, and more. Free prop trading simulator.';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Primary SEO ──────────────────────────────────── -->
    <title>{TITLE}</title>
    <meta name="description"        content={DESC} />
    <meta name="keywords"           content="prop firm calculator, FTMO calculator, Monte Carlo trading simulator, prop trading challenge, funded trader probability, pass probability, FundedNext, Funding Pips, Blue Guardian, FunderPro, Alpha Capital Group, win rate calculator, drawdown risk" />
    <meta name="author"             content="Raythan Web Design" />
    <meta name="robots"             content="index, follow, max-snippet:-1, max-image-preview:large" />
    <link rel="canonical"           href={SITE_URL} />

    <!-- ── Open Graph ──────────────────────────────────── -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={SITE_URL} />
    <meta property="og:site_name"   content="FundedCalc" />
    <meta property="og:locale"      content="en_US" />
    <meta property="og:title"       content={TITLE} />
    <meta property="og:description" content={DESC} />
    <meta property="og:image"       content={OG_IMAGE} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"   content="image/png" />
    <meta property="og:image:alt"    content="FundedCalc — Monte Carlo Prop Firm Challenge Simulator" />

    <!-- ── Twitter / X Cards ───────────────────────────── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content="@raythanweb" />
    <meta name="twitter:url"         content={SITE_URL} />
    <meta name="twitter:title"       content={TITLE} />
    <meta name="twitter:description" content={DESC} />
    <meta name="twitter:image"       content={OG_IMAGE} />
    <meta name="twitter:image:alt"   content="FundedCalc — Monte Carlo Prop Firm Challenge Simulator" />

    <!-- ── Favicon ──────────────────────────────────────── -->
    <link rel="icon"   type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon"   type="image/x-icon"  href="/favicon.ico" />
    <link rel="apple-touch-icon"            href="/apple-touch-icon.png" />

    <!-- ── Theme / mobile ───────────────────────────────── -->
    <meta name="theme-color" content="#060400" />
    <meta name="color-scheme" content="dark" />

    <!-- ── Performance: preconnect for Google Fonts ──────
         The @import inside App.jsx CSS string loads VT323 and
         Share Tech Mono. These preconnect hints eliminate the
         extra RTT for the font CDN, improving LCP on first load. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- ── Schema.org — WebApplication ─────────────────── -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "FundedCalc",
      "alternateName": "Prop Firm Challenge Calculator",
      "description": "Monte Carlo probability calculator for prop firm trading challenges. Supports FTMO, FundedNext, Funding Pips, Blue Guardian, FunderPro, Alpha Capital Group, MyFundedFX, Apex Trader, True Forex, and The 5%ers.",
      "url": "https://fundedcalc.fr",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web Browser",
      "browserRequirements": "Requires JavaScript",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "featureList": [
        "5,000 Monte Carlo simulations per run",
        "Multi-phase challenge support",
        "10 prop firm presets",
        "Win rate / R/R / risk analysis",
        "Max drawdown & daily drawdown simulation",
        "Equity path visualization",
        "Strategy advice engine",
        "Share results as image",
        "Bilingual EN / FR"
      ],
      "screenshot": "https://fundedcalc.fr/og-fundedcalc.png",
      "creator": {
        "@type": "Organization",
        "name": "Raythan Web Design",
        "url": "https://raythan.fr",
        "email": "raythanwebdesign@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Nantes",
          "addressCountry": "FR"
        }
      }
    }
    </script>
  </head>

  <body>
    <!--
      client:load — hydrates React immediately on page load.
      Appropriate here: the app is fully interactive with no
      static content above the fold worth server-rendering.
    -->
    <App client:load />
  </body>
</html>